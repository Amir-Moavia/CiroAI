GOOGLE_MAPS_API_KEY=YOUR_GOOGLE_MAPS_KEY
EXPO_PUBLIC_GOOGLE_MAPS_API_KEY=YOUR_GOOGLE_MAPS_KEY

# Groq keys (comma-separated) — primary LLM
EXPO_PUBLIC_GROQ_API_KEYS=YOUR_GROQ_KEY_1,YOUR_GROQ_KEY_2

# Gemini keys (comma-separated) — fallback LLM
EXPO_PUBLIC_GEMINI_API_KEYS=YOUR_GEMINI_KEY_1,YOUR_GEMINI_KEY_2

# google direction api key
EXPO_PUBLIC_GOOGLE_MAPS_API_KEY=YOUR_Google_direction_KEY
